---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Panel de Administración | Cardozo Performance">
    <div class="min-h-screen bg-neutral-950 font-workshop relative overflow-x-hidden">

        <!-- Top accent strip -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-600 via-yellow-400 to-blue-600 z-50"></div>

        <!-- Background SVG mechanical parts -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <defs>
            <g id="i-gear-lg">
                <path d="M0,-38 L5,-44 L10,-44 L15,-38 A38,38 0 0,1 18.5,-33.5 L22,-29 L26,-30 L28,-22 A28,28 0 0,1 27.5,-16 L26,-10 L30,-6 L27,2 A38,38 0 0,1 24,8 L20,14 L22,19 L15,23 A28,28 0 0,1 10,25 L6,28 L5,34 L-5,34 L-6,28 L-10,25 A28,28 0 0,1 -15,23 L-22,19 L-20,14 L-24,8 A38,38 0 0,1 -27,2 L-30,-6 L-26,-10 L-27.5,-16 A28,28 0 0,1 -28,-22 L-26,-30 L-22,-29 L-18.5,-33.5 A38,38 0 0,1 -15,-38 L-10,-44 L-5,-44 Z" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="0" cy="0" r="10" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <line x1="-10" y1="0" x2="10" y2="0" stroke="currentColor" stroke-width="1"/>
                <line x1="0" y1="-10" x2="0" y2="10" stroke="currentColor" stroke-width="1"/>
            </g>
            <g id="i-gear-sm">
                <path d="M0,-20 L4,-24 L8,-24 L10,-20 A20,20 0 0,1 14,-14 L18,-12 L18,-6 A14,14 0 0,1 14,-2 L12,4 L14,8 L10,12 A20,20 0 0,1 4,16 L2,20 L-2,20 L-4,16 A20,20 0 0,1 -10,12 L-14,8 L-12,4 A14,14 0 0,1 -14,-2 L-18,-6 L-18,-12 L-14,-14 A20,20 0 0,1 -10,-20 L-8,-24 L-4,-24 Z" fill="none" stroke="currentColor" stroke-width="1"/>
                <circle cx="0" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
            </g>
            <g id="i-wrench">
                <path d="M-4,-30 Q-2,-26 0,-22 L14,14 Q16,18 14,22 Q10,28 4,26 Q-2,24 -4,18 L-18,-18 Q-20,-22 -18,-26 Q-14,-32 -8,-32 Z" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="-12" cy="-26" r="7" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="8" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.2"/>
            </g>
            <g id="i-bolt">
                <polygon points="0,-14 12,-7 12,7 0,14 -12,7 -12,-7" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="0" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
            </g>
            </defs>
            <g opacity="0.04" color="#ffffff">
            <g transform="translate(80,180) rotate(15) scale(2.2)"><use href="#i-gear-lg"/></g>
            <g transform="translate(1300,600) rotate(-20) scale(2.8)"><use href="#i-gear-lg"/></g>
            </g>
            <g opacity="0.055" color="#ffffff">
            <g transform="translate(1200,90) rotate(8) scale(1.6)"><use href="#i-gear-lg"/></g>
            <g transform="translate(100,750) rotate(-12) scale(1.8)"><use href="#i-gear-lg"/></g>
            <g transform="translate(260,50) rotate(-15) scale(1.5)"><use href="#i-wrench"/></g>
            <g transform="translate(1050,600) rotate(20) scale(1.4)"><use href="#i-bolt"/></g>
            </g>
            <g opacity="0.07" color="#ef4444">
            <g transform="translate(1150,200) rotate(22) scale(1.2)"><use href="#i-gear-sm"/></g>
            <g transform="translate(50,680) rotate(55) scale(1.3)"><use href="#i-wrench"/></g>
            </g>
            <g opacity="0.07" color="#3b82f6">
            <g transform="translate(600,880) rotate(-10) scale(1.3)"><use href="#i-gear-sm"/></g>
            <g transform="translate(350,30) rotate(15) scale(1.1)"><use href="#i-bolt"/></g>
            </g>
        </svg>
        </div>

        <!-- Header -->
        <header class="relative z-10 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur-sm sticky top-0">
        <div class="max-w-screen-xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
            <div class="w-12 h-12 flex items-center justify-center">
                <img src="/logoCardozo.webp" alt="Cardozo Performance" class="w-12 h-12 object-contain" />
            </div>
            <div>
                <span class="text-white font-black text-xl tracking-widest uppercase">Cardozoperformance</span>
                <span class="block text-neutral-500 text-[10px] tracking-[0.3em] uppercase">Panel de Administración</span>
            </div>
            </div>
            <div class="flex items-center gap-3">
            <span id="adminGreeting" class="hidden md:block text-neutral-500 text-xs tracking-widest uppercase"></span>
            <button id="btnLogout"
                class="flex items-center gap-2 bg-red-900/20 hover:bg-red-900/40 border border-red-900/30 text-red-400 text-xs font-bold tracking-widest uppercase px-4 py-2 rounded-sm transition-all duration-200">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                </svg>
                Salir
            </button>
            </div>
        </div>
        </header>

        <!-- Hero -->
        <section class="relative z-10 max-w-screen-xl mx-auto px-6 pt-14 pb-8">
            <div class="mb-4">
                <div class="inline-flex items-center gap-2 bg-red-500/10 border border-red-500/20 rounded-sm px-3 py-1 mb-4">
                    <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></span>
                    <span class="text-red-400 text-xs tracking-[0.2em] uppercase font-semibold">Admin Online</span>
                </div>
                <h1 class="text-white text-4xl md:text-5xl font-black leading-none tracking-tight uppercase mb-3">
                    Panel <span class="text-red-500">Admin</span>
                </h1>
                <p class="text-neutral-500 text-sm max-w-sm">Gestioná los turnos y el historial de clientes del taller.</p>
            </div>
            <div class="flex items-center gap-3 mt-8">
                <div class="h-px flex-1 bg-gradient-to-r from-red-600/50 to-transparent"></div>
                <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
                </svg>
                <div class="h-px flex-1 bg-gradient-to-l from-blue-600/50 to-transparent"></div>
            </div>
        </section>

        <!-- Main -->
        <main class="relative z-10 max-w-screen-xl mx-auto px-6 pb-20">

            <!-- Stats rápidas -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
                <div class="bg-neutral-900 border border-neutral-800 rounded-sm px-4 py-4">
                    <span class="block text-neutral-500 text-[10px] font-bold tracking-widest uppercase mb-1">Total</span>
                    <span id="stat-total" class="text-white font-black text-2xl">—</span>
                </div>
                <div class="bg-neutral-900 border border-neutral-800 rounded-sm px-4 py-4">
                    <span class="block text-yellow-400/70 text-[10px] font-bold tracking-widest uppercase mb-1">Pendientes</span>
                    <span id="stat-pendiente" class="text-yellow-400 font-black text-2xl">—</span>
                </div>
                <div class="bg-neutral-900 border border-neutral-800 rounded-sm px-4 py-4">
                    <span class="block text-blue-400/70 text-[10px] font-bold tracking-widest uppercase mb-1">Confirmados</span>
                    <span id="stat-confirmado" class="text-blue-400 font-black text-2xl">—</span>
                </div>
                <div class="bg-neutral-900 border border-neutral-800 rounded-sm px-4 py-4">
                    <span class="block text-green-400/70 text-[10px] font-bold tracking-widest uppercase mb-1">Finalizados</span>
                    <span id="stat-finalizado" class="text-green-400 font-black text-2xl">—</span>
                </div>
            </div>

            <!-- Secciones -->
            <div class="flex items-center gap-3 mb-6">
                <span class="text-neutral-300 text-xs font-black tracking-[0.2em] uppercase">Secciones</span>
                <div class="h-px flex-1 bg-neutral-800"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                <!-- Card Turnos -->
                <a href="/admin/turnos" class="nav-card group block bg-neutral-900 border border-neutral-800 hover:border-red-600/50 rounded-sm overflow-hidden transition-all duration-200 shadow-lg hover:shadow-red-900/20">
                    <div class="bg-neutral-800 group-hover:bg-red-600/10 px-6 py-3 flex items-center justify-between transition-all duration-200">
                        <div class="flex items-center gap-2">
                            <div class="w-5 h-5 bg-red-600 flex items-center justify-center rounded-sm">
                                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7"/>
                                </svg>
                            </div>
                            <span class="text-white text-xs font-black tracking-[0.2em] uppercase">Turnos</span>
                        </div>
                        <svg class="w-4 h-4 text-neutral-600 group-hover:text-red-500 group-hover:translate-x-1 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </div>
                    <div class="px-6 py-6">
                        <p class="text-neutral-300 text-sm font-bold mb-2">Gestión de Turnos</p>
                        <p class="text-neutral-600 text-xs leading-relaxed mb-5">Visualizá y gestioná todos los turnos en formato Kanban. Confirmá, iniciá y finalizá turnos fácilmente.</p>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 rounded-full bg-yellow-400"></span>
                                <span class="text-neutral-500 text-[10px] tracking-widest uppercase">Pendientes</span>
                                <span id="card-pendiente" class="text-yellow-400 text-xs font-black ml-1">—</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 rounded-full bg-blue-500"></span>
                                <span class="text-neutral-500 text-[10px] tracking-widest uppercase">Confirmados</span>
                                <span id="card-confirmado" class="text-blue-400 text-xs font-black ml-1">—</span>
                            </div>
                        </div>
                    </div>
                </a>

                <!-- Card Clientes -->
                <a href="/admin/historial" class="nav-card group block bg-neutral-900 border border-neutral-800 hover:border-yellow-400/50 rounded-sm overflow-hidden transition-all duration-200 shadow-lg hover:shadow-yellow-900/10">
                    <div class="bg-neutral-800 group-hover:bg-yellow-400/10 px-6 py-3 flex items-center justify-between transition-all duration-200">
                        <div class="flex items-center gap-2">
                            <div class="w-5 h-5 bg-yellow-400 flex items-center justify-center rounded-sm">
                                <svg class="w-3 h-3 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <span class="text-white text-xs font-black tracking-[0.2em] uppercase">Clientes</span>
                        </div>
                        <svg class="w-4 h-4 text-neutral-600 group-hover:text-yellow-400 group-hover:translate-x-1 transition-all duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </div>
                    <div class="px-6 py-6">
                        <p class="text-neutral-300 text-sm font-bold mb-2">Historial de Reservas</p>
                        <p class="text-neutral-600 text-xs leading-relaxed mb-5">Revisá el historial completo de reservas. Filtrá por nombre, apellido o estado y editá cualquier turno.</p>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 rounded-full bg-neutral-400"></span>
                                <span class="text-neutral-500 text-[10px] tracking-widest uppercase">Total</span>
                                <span id="card-total" class="text-neutral-300 text-xs font-black ml-1">—</span>
                            </div>
                            <div class="flex items-center gap-1.5">
                                <span class="w-2 h-2 rounded-full bg-green-500"></span>
                                <span class="text-neutral-500 text-[10px] tracking-widest uppercase">Finalizados</span>
                                <span id="card-finalizado" class="text-green-400 text-xs font-black ml-1">—</span>
                            </div>
                        </div>
                    </div>
                </a>

            </div>
        </main>

    </div>
</Layout>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;900&display=swap');
    .font-workshop { font-family: 'Barlow', sans-serif; }
    .nav-card { animation: fadeUp 0.35s ease-out both; }
    .nav-card:nth-child(2) { animation-delay: 0.07s; }
    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(14px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

<script>
    const SESSION_KEY = 'admin_session';
    if (sessionStorage.getItem(SESSION_KEY) !== 'true') {
        window.location.href = '/admin/login';
    }

    const user = sessionStorage.getItem('admin_user');
    const greeting = document.getElementById('adminGreeting');
    if (user && greeting) {
        greeting.textContent = `Bienvenido, ${user}`;
        greeting.classList.remove('hidden');
    }

    document.getElementById('btnLogout')?.addEventListener('click', () => {
        sessionStorage.removeItem(SESSION_KEY);
        sessionStorage.removeItem('admin_user');
        window.location.href = '/admin/login';
    });

    // Stats mock — reemplazar con fetch real
    async function cargarStats() {
        await new Promise(r => setTimeout(r, 300));
        const mock = [
            { estado: 'pendiente' }, { estado: 'pendiente' },
            { estado: 'confirmado' }, { estado: 'enproceso' },
            { estado: 'finalizado' }, { estado: 'finalizado' },
            { estado: 'finalizado' }, { estado: 'cancelado' },
            { estado: 'confirmado' },
        ];
        const total      = mock.length;
        const pendiente  = mock.filter(t => t.estado === 'pendiente').length;
        const confirmado = mock.filter(t => t.estado === 'confirmado').length;
        const finalizado = mock.filter(t => t.estado === 'finalizado').length;

        document.getElementById('stat-total')!.textContent      = String(total);
        document.getElementById('stat-pendiente')!.textContent  = String(pendiente);
        document.getElementById('stat-confirmado')!.textContent = String(confirmado);
        document.getElementById('stat-finalizado')!.textContent = String(finalizado);
        document.getElementById('card-pendiente')!.textContent  = String(pendiente);
        document.getElementById('card-confirmado')!.textContent = String(confirmado);
        document.getElementById('card-total')!.textContent      = String(total);
        document.getElementById('card-finalizado')!.textContent = String(finalizado);
    }
    cargarStats();
</script>