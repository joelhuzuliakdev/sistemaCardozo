---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Acceso Admin | Cardozo Performance">
    <div class="min-h-screen bg-neutral-950 font-workshop relative overflow-x-hidden flex flex-col">

        <!-- Top accent strip -->
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-600 via-yellow-400 to-blue-600 z-50"></div>

        <!-- Background SVG mechanical parts (same as rest of project) -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
        <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <defs>
            <g id="l-gear-lg">
                <path d="M0,-38 L5,-44 L10,-44 L15,-38 A38,38 0 0,1 18.5,-33.5 L22,-29 L26,-30 L28,-22 A28,28 0 0,1 27.5,-16 L26,-10 L30,-6 L27,2 A38,38 0 0,1 24,8 L20,14 L22,19 L15,23 A28,28 0 0,1 10,25 L6,28 L5,34 L-5,34 L-6,28 L-10,25 A28,28 0 0,1 -15,23 L-22,19 L-20,14 L-24,8 A38,38 0 0,1 -27,2 L-30,-6 L-26,-10 L-27.5,-16 A28,28 0 0,1 -28,-22 L-26,-30 L-22,-29 L-18.5,-33.5 A38,38 0 0,1 -15,-38 L-10,-44 L-5,-44 Z" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="0" cy="0" r="10" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <line x1="-10" y1="0" x2="10" y2="0" stroke="currentColor" stroke-width="1"/>
                <line x1="0" y1="-10" x2="0" y2="10" stroke="currentColor" stroke-width="1"/>
            </g>
            <g id="l-gear-sm">
                <path d="M0,-20 L4,-24 L8,-24 L10,-20 A20,20 0 0,1 14,-14 L18,-12 L18,-6 A14,14 0 0,1 14,-2 L12,4 L14,8 L10,12 A20,20 0 0,1 4,16 L2,20 L-2,20 L-4,16 A20,20 0 0,1 -10,12 L-14,8 L-12,4 A14,14 0 0,1 -14,-2 L-18,-6 L-18,-12 L-14,-14 A20,20 0 0,1 -10,-20 L-8,-24 L-4,-24 Z" fill="none" stroke="currentColor" stroke-width="1"/>
                <circle cx="0" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
            </g>
            <g id="l-wrench">
                <path d="M-4,-30 Q-2,-26 0,-22 L14,14 Q16,18 14,22 Q10,28 4,26 Q-2,24 -4,18 L-18,-18 Q-20,-22 -18,-26 Q-14,-32 -8,-32 Z" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="-12" cy="-26" r="7" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="8" cy="20" r="7" fill="none" stroke="currentColor" stroke-width="1.2"/>
            </g>
            <g id="l-bolt">
                <polygon points="0,-14 12,-7 12,7 0,14 -12,7 -12,-7" fill="none" stroke="currentColor" stroke-width="1.2"/>
                <circle cx="0" cy="0" r="6" fill="none" stroke="currentColor" stroke-width="1"/>
            </g>
            </defs>
            <g opacity="0.04" color="#ffffff">
            <g transform="translate(80,180) rotate(15) scale(2.2)"><use href="#l-gear-lg"/></g>
            <g transform="translate(1300,600) rotate(-20) scale(2.8)"><use href="#l-gear-lg"/></g>
            </g>
            <g opacity="0.055" color="#ffffff">
            <g transform="translate(1200,90) rotate(8) scale(1.6)"><use href="#l-gear-lg"/></g>
            <g transform="translate(100,750) rotate(-12) scale(1.8)"><use href="#l-gear-lg"/></g>
            <g transform="translate(260,50) rotate(-15) scale(1.5)"><use href="#l-wrench"/></g>
            <g transform="translate(1050,600) rotate(20) scale(1.4)"><use href="#l-bolt"/></g>
            </g>
            <g opacity="0.07" color="#ef4444">
            <g transform="translate(1150,200) rotate(22) scale(1.2)"><use href="#l-gear-sm"/></g>
            <g transform="translate(50,680) rotate(55) scale(1.3)"><use href="#l-wrench"/></g>
            </g>
            <g opacity="0.07" color="#3b82f6">
            <g transform="translate(600,880) rotate(-10) scale(1.3)"><use href="#l-gear-sm"/></g>
            <g transform="translate(350,30) rotate(15) scale(1.1)"><use href="#l-bolt"/></g>
            </g>
            <g opacity="0.05" color="#facc15">
            <g transform="translate(200,200) rotate(30) scale(0.8)"><use href="#l-gear-sm"/></g>
            <g transform="translate(900,820) rotate(-22) scale(1.0)"><use href="#l-bolt"/></g>
            </g>
        </svg>
        </div>

        <!-- Header -->
        <header class="relative z-10 border-b border-neutral-800 bg-neutral-950/90 backdrop-blur-sm">
        <div class="max-w-screen-xl mx-auto px-6 py-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
            <div class="w-12 h-12 flex items-center justify-center">
                <img src="/logoCardozo.webp" alt="Cardozo Performance" class="w-12 h-12 object-contain" />
            </div>
            <div>
                <span class="text-white font-black text-xl tracking-widest uppercase">Cardozoperformance</span>
                <span class="block text-neutral-500 text-[10px] tracking-[0.3em] uppercase">Acceso Administrador</span>
            </div>
            </div>
            <div class="hidden md:flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-red-500"></span>
            <span class="text-neutral-500 text-xs tracking-widest uppercase">Área Restringida</span>
            </div>
        </div>
        </header>

        <!-- Login Content -->
        <main class="relative z-10 flex-1 flex items-center justify-center px-6 py-16">
        <div class="w-full max-w-md">

            <!-- Title -->
            <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 bg-red-500/10 border border-red-500/20 rounded-sm px-3 py-1 mb-4">
                <span class="w-1.5 h-1.5 bg-red-500 rounded-full"></span>
                <span class="text-red-400 text-xs tracking-[0.2em] uppercase font-semibold">Panel Admin</span>
            </div>
            <h1 class="text-white text-3xl font-black leading-none tracking-tight uppercase mb-2">
                Iniciar <span class="text-red-500">Sesión</span>
            </h1>
            <p class="text-neutral-500 text-sm">Ingresá tus credenciales para acceder al panel</p>
            </div>

            <!-- Login Form Card -->
            <div class="login-card bg-neutral-900 border border-neutral-800 rounded-sm shadow-2xl overflow-hidden">

            <!-- Card top bar -->
            <div class="bg-neutral-800 px-6 py-3 flex items-center justify-between">
                <span class="text-white text-xs font-bold tracking-[0.25em] uppercase">Credenciales</span>
                <div class="flex gap-1.5">
                <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400/70"></span>
                <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
                </div>
            </div>

            <div class="p-6 space-y-5">

                <!-- Error alert -->
                <div id="loginError" class="hidden items-center gap-3 bg-red-900/20 border border-red-700/40 rounded-sm px-4 py-3">
                <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
                </svg>
                <span id="loginErrorMsg" class="text-red-400 text-xs font-bold">Usuario o contraseña incorrectos</span>
                </div>

                <!-- Usuario -->
                <div>
                <label for="loginUsuario" class="block text-neutral-400 text-xs font-bold tracking-[0.15em] uppercase mb-2">
                    Usuario <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                    <input
                    type="text"
                    id="loginUsuario"
                    class="workshop-input w-full bg-neutral-800 border border-neutral-700 text-white placeholder-neutral-600 pl-10 pr-4 py-3 text-sm rounded-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/30 transition-all duration-200"
                    placeholder="admin"
                    autocomplete="username"
                    />
                </div>
                <span id="usuarioError" class="hidden text-red-500 text-xs mt-1">Ingresá el usuario</span>
                </div>

                <!-- Contraseña -->
                <div>
                <label for="loginPassword" class="block text-neutral-400 text-xs font-bold tracking-[0.15em] uppercase mb-2">
                    Contraseña <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                    <input
                    type="password"
                    id="loginPassword"
                    class="workshop-input w-full bg-neutral-800 border border-neutral-700 text-white placeholder-neutral-600 pl-10 pr-12 py-3 text-sm rounded-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500/30 transition-all duration-200"
                    placeholder="••••••••"
                    autocomplete="current-password"
                    />
                    <!-- Toggle show/hide password -->
                    <button type="button" id="togglePassword"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-neutral-600 hover:text-neutral-400 transition-colors"
                    aria-label="Mostrar contraseña">
                    <svg id="eyeIcon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    </button>
                </div>
                <span id="passwordError" class="hidden text-red-500 text-xs mt-1">Ingresá la contraseña</span>
                </div>

                <!-- Submit -->
                <div class="pt-1">
                <button
                    type="button"
                    id="btnLogin"
                    class="group w-full bg-red-600 hover:bg-red-500 text-white font-black tracking-[0.2em] uppercase text-sm py-4 px-8 rounded-sm transition-all duration-200 flex items-center justify-center gap-3 shadow-lg shadow-red-900/30 hover:shadow-red-900/50 active:scale-[0.98]"
                >
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span id="btnLoginText">Ingresar al Panel</span>
                </button>
                </div>

                <!-- Divider -->
                <div class="flex items-center gap-3 pt-1">
                <div class="h-px flex-1 bg-neutral-800"></div>
                <span class="text-neutral-700 text-[10px] tracking-widest uppercase">o</span>
                <div class="h-px flex-1 bg-neutral-800"></div>
                </div>

                <!-- Back to site -->
                <a href="/"
                class="flex items-center justify-center gap-2 text-neutral-500 hover:text-neutral-300 text-xs tracking-widest uppercase transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Volver al sitio
                </a>

            </div>
            </div>

            <!-- Hint -->
            <p class="text-center text-neutral-700 text-[10px] tracking-widest uppercase mt-6">
            Acceso exclusivo para personal autorizado
            </p>

        </div>
        </main>

    </div>
</Layout>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;900&display=swap');

    .font-workshop {
        font-family: 'Barlow', sans-serif;
    }

    .login-card {
        animation: fadeUp 0.4s ease-out both;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .workshop-input:focus {
        box-shadow: 0 0 0 2px rgb(59 130 246 / 0.1);
    }
</style>

<script>
    // ══════════════════════════════════════════
    // CREDENCIALES (cambiar por autenticación real)
    // ══════════════════════════════════════════
    const ADMIN_USER = 'admin';
    const ADMIN_PASS = 'cardozo2024';
    const SESSION_KEY = 'admin_session';

    // Redirigir si ya está logueado
    if (sessionStorage.getItem(SESSION_KEY) === 'true') {
        window.location.href = '/admin';
    }

    // Toggle mostrar/ocultar contraseña
    const toggleBtn = document.getElementById('togglePassword') as HTMLButtonElement;
    const passInput = document.getElementById('loginPassword') as HTMLInputElement;
    const eyeIcon   = document.getElementById('eyeIcon') as SVGElement;

    toggleBtn?.addEventListener('click', () => {
        const visible = passInput.type === 'text';
        passInput.type = visible ? 'password' : 'text';
        eyeIcon.innerHTML = visible
            ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>'
            : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>';
    });

    // Validación y login
    function showFieldError(id: string, show: boolean) {
        const el = document.getElementById(id);
        if (el) el.classList.toggle('hidden', !show);
    }

    function showLoginError(msg: string) {
        const box = document.getElementById('loginError') as HTMLElement;
        const txt = document.getElementById('loginErrorMsg') as HTMLElement;
        txt.textContent = msg;
        box.classList.remove('hidden');
        box.classList.add('flex');
        // Shake animation
        box.classList.add('shake');
        setTimeout(() => box.classList.remove('shake'), 500);
    }

    function hideLoginError() {
        const box = document.getElementById('loginError') as HTMLElement;
        box.classList.add('hidden');
        box.classList.remove('flex');
    }

    async function handleLogin() {
        const usuario  = (document.getElementById('loginUsuario')  as HTMLInputElement).value.trim();
        const password = (document.getElementById('loginPassword') as HTMLInputElement).value;
        const btn      = document.getElementById('btnLogin')     as HTMLButtonElement;
        const btnText  = document.getElementById('btnLoginText') as HTMLElement;

        hideLoginError();

        let valid = true;
        showFieldError('usuarioError',  !usuario);  if (!usuario)  valid = false;
        showFieldError('passwordError', !password); if (!password) valid = false;
        if (!valid) return;

        // Loading state
        btn.disabled = true;
        btnText.textContent = 'Verificando...';

        // Simular delay de verificación
        await new Promise(r => setTimeout(r, 600));

        if (usuario === ADMIN_USER && password === ADMIN_PASS) {
            sessionStorage.setItem(SESSION_KEY, 'true');
            sessionStorage.setItem('admin_user', usuario);
            btnText.textContent = '¡Acceso concedido!';
            btn.classList.replace('bg-red-600', 'bg-green-600');
            btn.classList.replace('hover:bg-red-500', 'hover:bg-green-500');
            await new Promise(r => setTimeout(r, 500));
            window.location.href = '/admin';
        } else {
            btn.disabled = false;
            btnText.textContent = 'Ingresar al Panel';
            showLoginError('Usuario o contraseña incorrectos');
            passInput.value = '';
            passInput.focus();
        }
    }

    // Click en botón
    document.getElementById('btnLogin')?.addEventListener('click', handleLogin);

    // Enter en campos
    document.getElementById('loginUsuario')?.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') {
            (document.getElementById('loginPassword') as HTMLInputElement).focus();
        }
    });
    document.getElementById('loginPassword')?.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter') handleLogin();
    });
</script>